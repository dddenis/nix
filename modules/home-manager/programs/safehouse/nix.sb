;; Nix support: store, volume, symlink resolution, and home-manager config
(allow file-read* (subpath "/nix"))
(allow file-read* (home-subpath "/.nix"))
(allow file-read* (home-subpath "/.nix-profile"))
(allow file-read* file-write* (home-subpath "/.cache/nix"))
(allow file-read* file-write* (home-subpath "/.local/state/nix"))
(allow file-read* file-write* (home-subpath "/.local/share/nix"))

;; Nix config (experimental-features, substituters, etc.)
(allow file-read* (subpath "/etc/nix"))
(allow file-read* (home-subpath "/.config/nix"))

;; Talk to the nix-daemon over its unix socket
(allow file-read* file-write* (literal "/nix/var/nix/daemon-socket/socket"))
(allow network-outbound (literal "/nix/var/nix/daemon-socket/socket"))
(allow file-read* (home-subpath "/.config/nvim"))
(allow file-read* file-write* (home-subpath "/.local/state/nvim"))
(allow file-read* file-write* (home-subpath "/.local/share/nvim"))
(allow file-read* file-write* (home-subpath "/.cache/nvim"))

;; User-installed binaries (claude, hasura, etc.)
(allow file-read* (home-subpath "/.local/bin"))
(allow process-exec* (home-subpath "/.local/bin"))

;; Bun-installed binaries (codex, etc.)
;; bin/ entries are symlinks into install/global/node_modules, so the whole
;; cache subtree needs read access for module resolution.
(allow file-read* (home-subpath "/.cache/.bun"))
(allow process-exec* (home-subpath "/.cache/.bun/bin"))
(allow process-exec* (home-subpath "/.cache/.bun/install/global/node_modules"))

;; Audio output for afplay-based hooks.
(allow mach-lookup
    (global-name "com.apple.audio.AudioComponentRegistrar")
    (global-name "com.apple.audio.audiohald")
)
