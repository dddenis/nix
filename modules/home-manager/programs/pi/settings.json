{
  "theme": "gruvbox-material-dark-medium",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "xhigh",
  "packages": [
    "git:github.com/obra/superpowers",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:@juicesharp/rpiv-todo"
  ],
  "hideThinkingBlock": true,
  "editorPaddingX": 1,
  "treeFilterMode": "user-only",
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "thinking": "xhigh"
      },
      "delegate": {
        "thinking": "xhigh"
      },
      "oracle": {
        "thinking": "xhigh"
      },
      "planner": {
        "thinking": "xhigh"
      },
      "researcher": {
        "thinking": "xhigh"
      },
      "reviewer": {
        "thinking": "xhigh"
      },
      "scout": {
        "thinking": "xhigh"
      },
      "worker": {
        "thinking": "xhigh"
      }
    }
  }
}
